<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputPath>$(LOCALAPPDATA)\TBot-cache\out\</OutputPath>
    <PublishDir>$(MSBuildProjectDirectory)\bin\</PublishDir>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
    <NoWarn>$(NoWarn);NETSDK1138;NU1902;NU1903;CS8618;CS8625;CS8602;CS8605</NoWarn>
    <NuGetAudit>false</NuGetAudit>
    <Nullable>disable</Nullable>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <SatelliteResourceLanguages></SatelliteResourceLanguages>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <Authors>TBot</Authors>
    <Version>0.3.4</Version>
    <StartupObject>Tbot.Program</StartupObject>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <Copyright>2023 © TBot</Copyright>
    <PackageLicenseExpression>https://licenses.nuget.org/MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://www.ogame-tbot.net</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ogame-tbot/TBot</RepositoryUrl>
    <AssemblyVersion>0.3.4.0</AssemblyVersion>
    <FileVersion>0.3.4.0</FileVersion>
    <Description>OGame Bot</Description>
    <SignAssembly>False</SignAssembly>
    <AssemblyOriginatorKeyFile>ELK-Lab.pfx</AssemblyOriginatorKeyFile>
    <DelaySign>false</DelaySign>
    <RootNamespace>Tbot</RootNamespace>
    <PackageReleaseNotes></PackageReleaseNotes>
    <Configurations>Debug;Release</Configurations>
    <ApplicationIcon>tbot.ico</ApplicationIcon>
    <PackageIcon></PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="tbot.ico" />
    <Content Include="ogamed.exe">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="profiles\**">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="6.0.1" />
    <PackageReference Include="Microsoft.Extensions.FileProviders.Physical" Version="6.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="RestSharp" Version="108.0.3" />
    <PackageReference Include="SixLabors.ImageSharp" Version="2.1.8" />
    <PackageReference Include="Telegram.Bot" Version="18.0.0" />
    <PackageReference Include="Telegram.Bot.Extensions.Polling" Version="1.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.Development.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="instance_settings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="settings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TBot.Ogame.Infrastructure\TBot.Ogame.Infrastructure.csproj" />
    <ProjectReference Include="..\TBot.WebUI\TBot.WebUI.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>portable</DebugType>
    <StaticWebAssetBasePath>wwwroot\</StaticWebAssetBasePath>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>$(MSBuildProjectDirectory)\bin\</PublishDir>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\README.md">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <TargetPath>README.md</TargetPath>
    </Content>
  </ItemGroup>

  <Target Name="RemoveRefsFolder" AfterTargets="Build">
    <RemoveDir Directories="$(OutputPath)refs" />
  </Target>

  <Target Name="RemoveStaticWebAssets" AfterTargets="Build">
    <ItemGroup>
      <_StaticWebAssets Remove="$(OutputPath)TBot.WebUI.staticwebassets.*" />
    </ItemGroup>
    <Delete Files="$(OutputPath)TBot.WebUI.staticwebassets.endpoints.json" />
    <Delete Files="$(OutputPath)TBot.WebUI.staticwebassets.runtime.json" />
  </Target>

</Project>

